---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Spot Arts — Tatouages temporaires",
  description = "Tatouages temporaires et semi-permanents, livraison rapide, paiement Mobile Money ou à la livraison."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-creme text-brun-dark font-body">
    <header class="bg-brun-dark text-creme sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-5 py-3">
        <a href="/" class="flex items-center gap-3">
          <img src="/logo.png" alt="Spot Arts" class="h-11 w-11 rounded-full object-cover" />
          <span class="font-display text-xl tracking-wide hidden sm:inline">Spot Arts</span>
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/catalogue" class="hover:text-terracotta transition-colors">Catalogue</a>
          <a href="/compte" class="hover:text-terracotta transition-colors">Mon compte</a>
          <a href="/panier" class="flex items-center gap-1 hover:text-terracotta transition-colors" id="cart-link">
            <span>Panier</span>
            <span id="cart-count" class="bg-terracotta text-brun-dark text-xs font-semibold rounded-full h-5 w-5 flex items-center justify-center">0</span>
          </a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="bg-brun-dark text-creme mt-24">
      <div class="max-w-6xl mx-auto px-5 py-10 grid gap-8 sm:grid-cols-3">
        <div>
          <img src="/logo.png" alt="Spot Arts" class="h-14 w-14 rounded-full object-cover mb-3" />
          <p class="text-sm text-creme/70">Tatouages temporaires et semi-permanents, livrés chez vous.</p>
        </div>
        <div class="text-sm">
          <p class="font-display text-terracotta mb-2">Contact</p>
          <p><a href="https://wa.me/237656701721" class="hover:text-terracotta">WhatsApp : +237 656 701 721</a></p>
        </div>
        <div class="text-sm">
          <p class="font-display text-terracotta mb-2">Paiement</p>
          <p class="text-creme/70">Mobile Money · Paiement à la livraison</p>
        </div>
      </div>
      <div class="text-center text-xs text-creme/50 pb-6">© {new Date().getFullYear()} Spot Arts. Tous droits réservés.</div>
    </footer>

    <script>
      function updateCartCount() {
        const cart = JSON.parse(localStorage.getItem('spotarts_cart') || '[]');
        const count = cart.reduce((sum, item) => sum + item.qty, 0);
        const el = document.getElementById('cart-count');
        if (el) el.textContent = String(count);
      }
      updateCartCount();
      window.addEventListener('storage', updateCartCount);
      document.addEventListener('cart-updated', updateCartCount);
    </script>
  </body>
</html>
