---
import Layout from "../../layouts/Layout.astro";
import { products, formatPrice } from "../../data/products.js";

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = products.find(p => p.slug === slug);
if (!product) return Astro.redirect("/catalogue");
---
<Layout title={`${product.name} — Spot Arts`} description={product.description}>
  <section class="max-w-5xl mx-auto px-5 py-10 grid md:grid-cols-2 gap-10">
    <div class="aspect-square rounded-2xl bg-terracotta-light overflow-hidden">
      <img src={product.image} alt={product.name} class="w-full h-full object-cover" onerror="this.style.display='none'" />
    </div>
    <div>
      <p class="text-sm text-terracotta-dark mb-2">{product.category}</p>
      <h1 class="font-display text-3xl text-brun-dark mb-4">{product.name}</h1>
      <div class="flex items-baseline gap-3 mb-6">
        {product.oldPrice && <span class="text-brun/40 line-through">{formatPrice(product.oldPrice)}</span>}
        <span class="text-2xl font-semibold text-terracotta-dark">{formatPrice(product.price)}</span>
      </div>
      <p class="text-brun/70 mb-8 leading-relaxed">{product.description}</p>
      <a href={`https://wa.me/237656701721?text=${encodeURIComponent("Bonjour, je veux commander : " + product.name)}`}
        class="block text-center w-full bg-brun-dark text-creme font-medium py-3 rounded-full hover:bg-brun transition-colors">
        Commander sur WhatsApp
      </a>
    </div>
  </section>
</Layout>
