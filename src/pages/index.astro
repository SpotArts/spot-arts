---
import Layout from "../layouts/Layout.astro";
import { products, formatPrice } from "../data/products.js";

const categories = [...new Set(products.map(p => p.category))];
const featured = products.slice(0, 4);
---
<Layout>
  <section class="bg-brun-dark text-creme">
    <div class="max-w-6xl mx-auto px-5 py-20 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="font-display italic text-terracotta mb-3">Exprime-toi, sans engagement</p>
        <h1 class="font-display text-4xl md:text-5xl leading-tight mb-5">
          Des tatouages temporaires qui durent, sans les regrets.
        </h1>
        <p class="text-creme/70 mb-8 max-w-md">
          Tatouages temporaires et semi-permanents, à prix juste.
          Paiement Mobile Money ou à la livraison.
        </p>
        <a href="/catalogue" class="inline-block bg-terracotta text-brun-dark font-medium px-7 py-3 rounded-full hover:bg-terracotta-light transition-colors">
          Voir le catalogue
        </a>
      </div>
      <div class="flex justify-center">
        <div class="rounded-full border-2 border-terracotta/40 p-6">
          <img src="/logo.png" alt="Spot Arts" class="h-56 w-56 rounded-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-14">
    <h2 class="font-display text-2xl text-brun-dark mb-6">Catégories</h2>
    <div class="flex flex-wrap gap-3">
      {categories.map(cat => (
        <a href={`/catalogue?categorie=${encodeURIComponent(cat)}`}
           class="px-5 py-2 rounded-full border border-brun/20 text-sm hover:bg-terracotta/20 transition-colors">
          {cat}
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-6 pb-20">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-2xl text-brun-dark">Produits</h2>
      <a href="/catalogue" class="text-sm text-brun/60 hover:text-terracotta-dark">Tout voir →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {featured.map(p => (
        <a href={`/produit/${p.slug}`} class="group">
          <div class="aspect-square rounded-full bg-terracotta-light overflow-hidden mb-3">
            <img src={p.image} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" onerror="this.style.display='none'" />
          </div>
          <p class="font-medium text-sm text-brun-dark">{p.name}</p>
          <p class="text-terracotta-dark text-sm">{formatPrice(p.price)}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
